# ==========================================
# 服务器配置
# ==========================================
APP_NAME=BrokerAssist API
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ==========================================
# 数据库配置 (必填)
# ==========================================
DATABASE_URL=postgresql+asyncpg://kaitang@localhost:5432/brokerassist

# ==========================================
# Supabase 配置（可选，用于录音存储）
# ==========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=recordings

# ==========================================
# AI 服务配置 (必填)
# ==========================================
# Kimi (Moonshot AI)
KIMI_API_KEY=sk-your-api-key
KIMI_BASE_URL=https://api.moonshot.cn
KIMI_MODEL=moonshot-v1-8k

# 讯飞语音转写（可选）
XUNFEI_APP_ID=your-app-id
XUNFEI_API_KEY=your-api-key
XUNFEI_API_SECRET=your-api-secret

# ==========================================
# 安全配置
# ==========================================
DEFAULT_USER_ID=default-user

# ==========================================
# 日志配置
# ==========================================
LOG_LEVEL=INFO
