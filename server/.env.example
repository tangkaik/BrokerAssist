APP_NAME=BrokerAssist API
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8001

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/brokerassist

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn
KIMI_MODEL=moonshot-v1-8k

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
DASHSCOPE_VL_MODEL=qwen3-vl-flash

GAODE_API_KEY=

AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_TOKEN_EXPIRE_DAYS=30

CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MAX_UPLOAD_IMAGE_COUNT=6
MAX_UPLOAD_IMAGE_BYTES=10485760
ALLOWED_IMAGE_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/heic,image/heif

